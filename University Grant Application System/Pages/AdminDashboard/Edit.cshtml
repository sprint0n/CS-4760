@page
@model University_Grant_Application_System.Pages.AdminDashboard.EditModel

@{
    ViewData["Title"] = "Edit";

    // Dynamically assign the layout based on the logged-in user's role
    if (User.HasClaim("IsAdmin", "True"))
    {
        Layout = "_AdminLayout";
    }
    else if (User.HasClaim("CommitteeStatus", "chair"))
    {
        Layout = "_CommitteeLayout";
    }
    else if (User.HasClaim("CommitteeStatus", "member"))
    {
        Layout = "_ComMemberLayout";
    }
    else if (User.HasClaim("userType", "chair"))
    {
        Layout = "_DeptChairLayout";
    }
    else
    {
        Layout = "_Layout";
    }
}

<h1>Edit</h1>

<h4>Users</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <form method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="Users.UserId" />
            <div class="form-group">
                <label asp-for="Users.FirstName" class="control-label"></label>
                <input asp-for="Users.FirstName" class="form-control" />
                <span asp-validation-for="Users.FirstName" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Users.LastName" class="control-label"></label>
                <input asp-for="Users.LastName" class="form-control" />
                <span asp-validation-for="Users.LastName" class="text-danger"></span>
            </div>
           <div class="mb-3">
                <label asp-for="Users.CollegeId" class="form-label">College</label>
                <select id="collegeSelect" asp-for="Users.CollegeId" asp-items="Model.CollegeOptions" class="form-select">
                    <option value="">Select a college</option>
                </select>
            </div>

            <div class="mb-3">
                <label asp-for="Users.SchoolId" class="form-label">School</label>
                <select id="schoolSelect" asp-for="Users.SchoolId" asp-items="Model.SchoolOptions" class="form-select">
                    <option value="">Select a school</option>
                </select>
            </div>

            <div class="mb-3">
                <label asp-for="Users.DepartmentId" class="form-label">Department</label>
                <select id="departmentSelect" asp-for="Users.DepartmentId" asp-items="Model.DepartmentOptions" class="form-select">
                    <option value="">Select a department</option>
                </select>
            </div>
            <div class="form-group">
                <label asp-for="Users.Email" class="control-label"></label>
                <input asp-for="Users.Email" class="form-control" />
                <span asp-validation-for="Users.Email" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Users.AccountID" class="control-label"></label>
                <input asp-for="Users.AccountID" class="form-control" />
                <span asp-validation-for="Users.AccountID" class="text-danger"></span>
            </div>
            <div class="form-group">
                <input type="submit" value="Save" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div>
    <a asp-page="./Index">Back to List</a>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}

    <script>
        $(document).ready(function () {
            $('#collegeSelect').change(function () {
                var collegeId = $(this).val();
                $('#schoolSelect').empty().append('<option value="">Select a school</option>');
                $('#departmentSelect').empty().append('<option value="">Select a department</option>');

                if (collegeId) {
                    $.getJSON(`?handler=Schools&collegeId=${collegeId}`, function (data) {
                        $.each(data, function (i, item) {
                            $('#schoolSelect').append(`<option value="${item.schoolId}">${item.schoolName}</option>`);
                        });
                    });
                }
            });

            $('#schoolSelect').change(function () {
                var schoolId = $(this).val();
                $('#departmentSelect').empty().append('<option value="">Select a department</option>');

                if (schoolId) {
                    $.getJSON(`?handler=Departments&schoolId=${schoolId}`, function (data) {
                        $.each(data, function (i, item) {
                            $('#departmentSelect').append(`<option value="${item.departmentId}">${item.departmentName}</option>`);
                        });
                    });
                }
            });
        });
    </script>
}

