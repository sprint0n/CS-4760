@page
@model RegisterModel
@{
    ViewData["Title"] = "Register";
    Layout = "_LoginLayout";
}

<div class="login-page">

    <!-- Floating dark mode toggle -->
    <button id="themeToggle" class="login-theme-toggle" aria-label="Toggle dark mode" title="Toggle dark mode">
        <svg id="icon-moon" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
        </svg>
        <svg id="icon-sun" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true" style="display:none">
            <circle cx="12" cy="12" r="5"/>
            <path d="M12 1v2M12 21v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M1 12h2M21 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42"/>
        </svg>
    </button>

    <!-- Logo / Brand -->
    <div class="login-brand">
        <div class="login-logo">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 64 72" fill="none" aria-hidden="true">
                <path d="M32 2 L60 14 L60 36 C60 52 48 64 32 70 C16 64 4 52 4 36 L4 14 Z" fill="rgba(255,255,255,0.12)" stroke="rgba(200,169,81,0.8)" stroke-width="2"/>
                <path d="M32 12 L50 20 L50 37 C50 48 42 57 32 61 C22 57 14 48 14 37 L14 20 Z" fill="rgba(200,169,81,0.15)" stroke="rgba(200,169,81,0.5)" stroke-width="1.5"/>
                <text x="32" y="44" text-anchor="middle" font-family="Georgia,serif" font-size="22" font-weight="bold" fill="rgba(200,169,81,0.95)">G</text>
            </svg>
        </div>
        <div class="brand-title">University Grant Portal</div>
    </div>

    <!-- Register card -->
    <div class="login-card register-card">
        <div class="login-card-header">
            <h2>Create Account</h2>
            <p>Register to start managing your grant applications</p>
        </div>

        <hr class="login-divider" />

        <form method="post" novalidate>
            @Html.AntiForgeryToken()

            <div class="row">
                <div class="col-md-6 mb-3">
                    <label asp-for="Input.FirstName" class="form-label">First Name</label>
                    <input asp-for="Input.FirstName" class="form-control" placeholder="John" />
                    <span asp-validation-for="Input.FirstName" class="text-danger small"></span>
                </div>

                <div class="col-md-6 mb-3">
                    <label asp-for="Input.LastName" class="form-label">Last Name</label>
                    <input asp-for="Input.LastName" class="form-control" placeholder="Doe" />
                    <span asp-validation-for="Input.LastName" class="text-danger small"></span>
                </div>
            </div>

            <div class="mb-3">
                <label asp-for="Input.Birthday" class="form-label">Birthday</label>
                <input asp-for="Input.Birthday" type="date" class="form-control" />
                <span asp-validation-for="Input.Birthday" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Input.Email" class="form-label">Email Address</label>
                <input asp-for="Input.Email" type="email" class="form-control" placeholder="you@university.edu" autocomplete="email" />
                <span asp-validation-for="Input.Email" class="text-danger small"></span>
            </div>

            <div class="row">
                <div class="col-md-6 mb-3">
                    <label asp-for="Input.Password" class="form-label">Password</label>
                    <input asp-for="Input.Password" type="password" class="form-control" placeholder="••••••••" autocomplete="new-password" />
                    <span asp-validation-for="Input.Password" class="text-danger small"></span>
                </div>

                <div class="col-md-6 mb-3">
                    <label asp-for="Input.ConfirmPassword" class="form-label">Confirm Password</label>
                    <input asp-for="Input.ConfirmPassword" type="password" class="form-control" placeholder="••••••••" autocomplete="new-password" />
                    <span asp-validation-for="Input.ConfirmPassword" class="text-danger small"></span>
                </div>
            </div>

            <div class="mb-3">
                <label asp-for="Input.AccountIndex" class="form-label">Account Index</label>
                <input asp-for="Input.AccountIndex" class="form-control" placeholder="6-digit number" />
                <span asp-validation-for="Input.AccountIndex" class="text-danger small"></span>
            </div>

            <hr class="login-divider" />

            <div class="mb-3">
                <label asp-for="Input.SelectedCollegeId" class="form-label">College</label>
                <select id="collegeSelect" asp-for="Input.SelectedCollegeId" asp-items="Model.CollegeOptions" class="form-select">
                    <option value="">Select a college</option>
                </select>
                <span asp-validation-for="Input.SelectedCollegeId" class="text-danger small"></span>
            </div>

            <div class="row">
                <div class="col-md-6 mb-3">
                    <label asp-for="Input.SelectedSchoolId" class="form-label">School</label>
                    <select id="schoolSelect" asp-for="Input.SelectedSchoolId" asp-items="Model.SchoolOptions" class="form-select">
                        <option value="">Select a school</option>
                    </select>
                    <span asp-validation-for="Input.SelectedSchoolId" class="text-danger small"></span>
                </div>

                <div class="col-md-6 mb-3">
                    <label asp-for="Input.SelectedDepartmentId" class="form-label">Department</label>
                    <select id="departmentSelect" asp-for="Input.SelectedDepartmentId" asp-items="Model.DepartmentOptions" class="form-select">
                        <option value="">Select a department</option>
                    </select>
                    <span asp-validation-for="Input.SelectedDepartmentId" class="text-danger small"></span>
                </div>
            </div>

            <div class="d-grid mb-3">
                <button type="submit" class="btn btn-accent btn-lg">Register</button>
            </div>

            <div class="text-center">
                <a asp-page="/Index" class="login-link">Already have an account? Sign in</a>
            </div>
        </form>
    </div>

    <div class="login-footer-text">
        &copy; 2026 University Grant Application System
    </div>
</div>

@*Shows client side errors in real time*@
@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script>
        const collegeSelect = document.getElementById('collegeSelect');
        const schoolSelect = document.getElementById('schoolSelect');
        const departmentSelect = document.getElementById('departmentSelect');

        const resetDropdown = (target, text) => {
            target.innerHTML = `<option value="">${text}</option>`;
            target.disabled = true;
        }

        collegeSelect.addEventListener('change', async function() {
            const collegeId = this.value;
            resetDropdown(schoolSelect, "Select a school");
            resetDropdown(departmentSelect, "Select a department");

            if(collegeId){
                const response = await fetch(`?handler=Schools&collegeId=${collegeId}`);
                const schools = await response.json();

                schools.forEach(s => {
                       schoolSelect.innerHTML += `<option value="${s.schoolId}">${s.schoolName}</option>`;                
                });
                schoolSelect.disabled = false;
            }
        });

         schoolSelect.addEventListener('change', async function() {
            const schoolId = this.value;
            resetDropdown(departmentSelect, "Select a department");

            if(schoolId){
                const response = await fetch(`?handler=Departments&schoolId=${schoolId}`);
                const depts = await response.json();

                depts.forEach(d => {
                    departmentSelect.innerHTML += `<option value="${d.departmentId}">${d.departmentName}</option>`
                });
                departmentSelect.disabled = false;
            }
        });
    </script>
}
